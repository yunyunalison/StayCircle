# StayCircle environment example (copy to .env and adjust as needed)
# NOTE: Never commit real secrets. This file is for local development/demo.

# Frontend (Next.js)
# Public variable read by browser and server-side code in Next.js
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend (FastAPI)
# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Uvicorn worker count (prod can override to 4+)
UVICORN_WORKERS=2

# Database URL
# For Docker Compose (dev/prod) with MySQL (service name "mysql"):
# Example DSN (default): mysql+pymysql://staycircle:staycircle@mysql:3306/staycircle
DATABASE_URL=mysql+pymysql://staycircle:staycircle@mysql:3306/staycircle
# SQLite fallbacks (useful for local, non-container dev):
# DATABASE_URL=sqlite:///./data.db
# For legacy prod with a volume:
# DATABASE_URL=sqlite:////data/data.db

# MySQL settings (used by docker-compose.*.yml)
MYSQL_DB=staycircle
MYSQL_USER=staycircle
MYSQL_PASSWORD=staycircle
MYSQL_ROOT_PASSWORD=devroot
# Optional host/port overrides (normally not needed; compose uses service name "mysql")
# MYSQL_HOST=mysql
# MYSQL_PORT=3306

# Auth (dev default is defined in code; set a stronger value locally if desired)
STAYCIRCLE_JWT_SECRET=change-me-dev-secret

# Redis (optional) — minimal rate limiting
# Disabled by default. Enable to turn on per-IP fixed-window limits for select endpoints.
REDIS_ENABLED=false
# In Docker Compose, the Redis service is named "redis"
REDIS_URL=redis://redis:6379/0
# Rate limit window and per-endpoint limits (defaults shown)
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_LOGIN_PER_WINDOW=10
RATE_LIMIT_SIGNUP_PER_WINDOW=5
RATE_LIMIT_WRITE_PER_WINDOW=30

# Payments (Stripe test mode)
# Backend secret key (server-side only)
STRIPE_SECRET_KEY=sk_test_xxx
# Webhook signing secret from Stripe CLI/dashboard
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Frontend publishable key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Booking hold window (minutes) for pending_payment
HOLD_MINUTES=15
