# StayCircle Monorepo .gitignore
# Backend: Python (FastAPI), Frontend: Next.js/React, Docker, DevOps

# -----------------------------
# OS / Editors / IDE metadata
# -----------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*.orig
.idea/
.vscode/
.history/

# -----------------------------
# Git helpers
# -----------------------------
*.patch
*.diff

# -----------------------------
# Logs & diagnostics
# -----------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------
# Environment & secrets
# Keep .env.example tracked for reference
# -----------------------------
.env
.env.*
!.env.example

# -----------------------------
# Python (Backend)
# -----------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
pip-wheel-metadata/
build/
dist/
.eggs/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/
.ipynb_checkpoints/
.pyre/
.dmypy.json
.pytype/

# -----------------------------
# Node / Next.js (Frontend)
# -----------------------------
node_modules/
.next/
.turbo/
.cache/
out/
coverage/
coverage.lcov
lcov-report/

# -----------------------------
# Frontend/JS builds
# -----------------------------
dist/
build/
.storybook-out/
storybook-static/

# -----------------------------
# Package managers
# -----------------------------
.pnp.*
.pnpm-debug.log*
.npm/
.yarn/*
!.yarn/releases
!.yarn/plugins
!.yarn/sdks
!.yarn/versions

# -----------------------------
# Databases / storage / data dumps
# -----------------------------
*.sqlite
*.sqlite3
*.db
db-data/
redis-data/
meilisearch_data/
search-data/
docker-data/
data/

# -----------------------------
# Docker / containers / deploy
# -----------------------------
.docker/
.vercel/
.k8s/
minikube/

# -----------------------------
# Archives and artifacts
# -----------------------------
*.tar
*.tgz
*.zip

# -----------------------------
# CI/test reports
# -----------------------------
coverage.xml
pytest.xml
report.xml

# -----------------------------
# OS specific backup
# -----------------------------
*.bak